# ─── Copy to .env for local development ────────────────────────────────────
# In AWS (EKS), DO NOT set AWS credentials or AWS_ENDPOINT_URL — IRSA provides
# credentials and the SDK reaches the real AWS endpoints automatically.

# Local mode: "local" points the AWS SDK at LocalStack. "aws" uses real AWS.
RUNTIME_ENV=local

# LocalStack endpoint (ignored when RUNTIME_ENV=aws)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1

# Dummy creds satisfy boto3 against LocalStack. Real AWS uses IRSA, not these.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─── Resource names (shared across services) ───────────────────────────────
S3_BUCKET=resume-screener-files
DDB_TABLE=resume-screener
SQS_QUEUE_URL=http://localhost:4566/000000000000/resume-screener-jobs
SQS_DLQ_URL=http://localhost:4566/000000000000/resume-screener-jobs-dlq

# Pre-signed URL lifetime (seconds)
PRESIGN_EXPIRY=900

# ─── Worker / LLM ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile
WORKER_POLL_WAIT_SECONDS=20
WORKER_BATCH_SIZE=5

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
